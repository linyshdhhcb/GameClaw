<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>ai.gameclaw</groupId>
    <artifactId>gameclaw</artifactId>
    <version>1.0.0-SNAPSHOT</version>
    <packaging>pom</packaging>
    <name>GameClaw</name>
    <description>GameClaw - Game Enterprise R&amp;D AI Agent Control Plane</description>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>4.0.6</version>
        <relativePath/>
    </parent>

    <modules>
        <module>base</module>
        <module>providers/anthropic</module>
        <module>providers/openai</module>
        <module>providers/ollama</module>
        <module>providers/google</module>
        <module>plugins/brave</module>
        <module>plugins/discord</module>
        <module>plugins/playwright</module>
        <module>plugins/telegram</module>
        <module>mcp-servers/java</module>
        <module>app</module>
    </modules>

    <properties>
        <java.version>25</java.version>
        <spring-ai.version>2.0.0-M6</spring-ai.version>
        <spring-modulith.version>2.0.6</spring-modulith.version>
        <spring-ai-agent-utils.version>0.7.0</spring-ai-agent-utils.version>
        <tool-search.version>2.1.0</tool-search.version>
        <jobrunr.version>8.6.0</jobrunr.version>
        <pebble.version>4.1.1</pebble.version>
        <jda.version>6.4.1</jda.version>
        <playwright.version>1.52.0</playwright.version>
        <telegrambots.version>9.5.0</telegrambots.version>
        <commonmark.version>0.28.0</commonmark.version>
        <testcontainers.version>1.21.4</testcontainers.version>
        <resilience4j.version>2.4.0</resilience4j.version>
        <archunit.version>1.4.2</archunit.version>
        <logstash-logback-encoder.version>8.0</logstash-logback-encoder.version>
        <spotbugs-maven-plugin.version>4.9.3.0</spotbugs-maven-plugin.version>
        <spotbugs.version>4.9.3</spotbugs.version>
        <maven-checkstyle-plugin.version>3.6.0</maven-checkstyle-plugin.version>
    </properties>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>org.springframework.ai</groupId>
                <artifactId>spring-ai-bom</artifactId>
                <version>${spring-ai.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
            <dependency>
                <groupId>org.springframework.modulith</groupId>
                <artifactId>spring-modulith-bom</artifactId>
                <version>${spring-modulith.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>

            <dependency>
                <groupId>org.testcontainers</groupId>
                <artifactId>testcontainers-bom</artifactId>
                <version>${testcontainers.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>

            <dependency>
                <groupId>ai.gameclaw</groupId>
                <artifactId>gameclaw-base</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ai.gameclaw</groupId>
                <artifactId>gameclaw-provider-anthropic</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ai.gameclaw</groupId>
                <artifactId>gameclaw-provider-openai</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ai.gameclaw</groupId>
                <artifactId>gameclaw-provider-ollama</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ai.gameclaw</groupId>
                <artifactId>gameclaw-provider-google</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ai.gameclaw</groupId>
                <artifactId>gameclaw-plugin-brave</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ai.gameclaw</groupId>
                <artifactId>gameclaw-plugin-discord</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ai.gameclaw</groupId>
                <artifactId>gameclaw-plugin-playwright</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ai.gameclaw</groupId>
                <artifactId>gameclaw-plugin-telegram</artifactId>
                <version>${project.version}</version>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <repositories>
        <repository>
            <id>maven-central</id>
            <url>https://repo1.maven.org/maven2</url>
        </repository>
        <repository>
            <id>spring-snapshot</id>
            <url>https://repo.spring.io/snapshot</url>
            <snapshots><enabled>true</enabled></snapshots>
        </repository>
        <repository>
            <id>spring-milestone</id>
            <url>https://repo.spring.io/milestone</url>
        </repository>
        <repository>
            <id>central-portal-snapshots</id>
            <url>https://central.sonatype.com/repository/maven-snapshots/</url>
            <snapshots><enabled>true</enabled></snapshots>
        </repository>
    </repositories>

    <pluginRepositories>
        <pluginRepository>
            <id>spring-snapshot</id>
            <url>https://repo.spring.io/snapshot</url>
            <snapshots><enabled>true</enabled></snapshots>
        </pluginRepository>
        <pluginRepository>
            <id>spring-milestone</id>
            <url>https://repo.spring.io/milestone</url>
        </pluginRepository>
    </pluginRepositories>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <configuration>
                    <source>${java.version}</source>
                    <target>${java.version}</target>
                    <release>${java.version}</release>
                    <compilerArgs>
                        <arg>--enable-preview</arg>
                    </compilerArgs>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <configuration>
                    <argLine>--enable-preview</argLine>
                    <includes>
                        <include>**/*Test.java</include>
                        <include>**/*Tests.java</include>
                    </includes>
                </configuration>
            </plugin>
            <plugin>
                <groupId>com.github.spotbugs</groupId>
                <artifactId>spotbugs-maven-plugin</artifactId>
                <version>${spotbugs-maven-plugin.version}</version>
                <dependencies>
                    <dependency>
                        <groupId>com.github.spotbugs</groupId>
                        <artifactId>spotbugs</artifactId>
                        <version>${spotbugs.version}</version>
                    </dependency>
                </dependencies>
                <configuration>
                    <effort>Low</effort>
                    <threshold>High</threshold>
                    <excludeFilterFile>${project.basedir}/../spotbugs-exclude.xml</excludeFilterFile>
                    <jvmArgs>--enable-preview</jvmArgs>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-checkstyle-plugin</artifactId>
                <version>${maven-checkstyle-plugin.version}</version>
                <configuration>
                    <configLocation>${project.basedir}/../checkstyle.xml</configLocation>
                    <consoleOutput>true</consoleOutput>
                    <failOnViolation>false</failOnViolation>
                    <violationSeverity>warning</violationSeverity>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
